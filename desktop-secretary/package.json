{
  "name": "desktop-secretary",
  "version": "1.0.0",
  "description": "桌面小秘书 - 智能待办事项管理工具",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest"
  },
  "keywords": [
    "electron",
    "desktop",
    "todo",
    "pet"
  ],
  "author": "lmme",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^10.0.0",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.lmme.desktop-secretary",
    "productName": "桌面小秘书",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "resources/icon.ico"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  }
}
